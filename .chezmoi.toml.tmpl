[git]
    autoCommit = true
    autoPush = true

[data]
    git_name          = {{ promptStringOnce . "git_name" "Git name" | quote }}
    git_email         = {{ promptStringOnce . "git_email" "Git email" | quote }}
    git_signingkey    = {{ promptStringOnce . "git_signingkey" "Git signing key" | quote }}
    is_hyprland       = {{ promptBoolOnce . "is_hyprland" "Is this a Hyprland system" }}
{{- if promptBoolOnce . "is_hyprland" "Is this a Hyprland system" }}
    aq_drm_devices    = {{ promptStringOnce . "aq_drm_devices" "AQ_DRM_DEVICES (e.g. /dev/dri/card1:/dev/dri/card0, blank to skip)" | quote }}
    libva_driver_name = {{ promptStringOnce . "libva_driver_name" "LIBVA_DRIVER_NAME (e.g. iHD, radeonsi, blank to skip)" | quote }}
    kb_layout         = {{ promptStringOnce . "kb_layout" "Keyboard layout (e.g. us, gb, de)" | quote }}
    monitor_profiles  = {{ if hasKey . "monitor_profiles" }}{{ .monitor_profiles | toJson }}{{ else }}[]{{ end }}
{{- if hasKey . "kb_devices" }}

[data.kb_devices]
{{- range $name, $layout := .kb_devices }}
    {{ $name | quote }} = {{ $layout | quote }}
{{- end }}
{{- end }}
{{- end }}
