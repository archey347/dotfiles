# Appearance — matches Waybar pill aesthetic
font=Noto Serif, Liberation Serif 11
background-color=#{{ .theme.accent_strong }}
text-color=#FFFFFFD9
border-color=#{{ .theme.accent }}
border-size=1
border-radius=14
padding=14
margin=8
width=360
max-icon-size=48
icons=1
markup=1
actions=1
format=<b>%s</b>\n%b
progress-color=over #{{ .theme.success }}66

# Layout
max-visible=4
layer=overlay
anchor=top-right

# Behavior
default-timeout=20000
on-button-left=dismiss
on-button-right=dismiss-all
group-by=app-name

[urgency=low]
border-color=#{{ .theme.accent_strong }}

[urgency=critical]
border-color=#{{ .theme.error }}CC
default-timeout=0
